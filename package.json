    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^2.1.9"
  }
